#version 430
// psi -> velocity with the spherical operator pairing (the only pairing that
// is divergence-free on the sphere):
//   u = -dpsi/dphi                  (eastward physical speed)
//   v = (1/cos phi) dpsi/dlambda    (northward physical speed)
// Central differences, X periodic, Y clamped (pole rows are velocity-faded
// anyway). A polar fade mask zeroes velocity toward the caps until the
// Phase 3b polar patches take over.

layout(local_size_x = 16, local_size_y = 16) in;

#include "common.glsl"

layout(rg32f, binding = 0) writeonly uniform image2D out_vel;

uniform sampler2D u_psi;            // r32f
uniform sampler2D u_profile_stamp;  // (t0, t1, polar_fade, -) by latitude
uniform ivec2 u_size;

#if DOMAIN == 0
// Active convective outbreaks: brief divergent outflow impulses (the one
// intentional departure from solenoidal flow; tracer thinning reads as the
// spreading plume). Up to 2 concurrently.
uniform int u_outbreak_count;
uniform vec4 u_outbreaks[2];  // lon, lat, radius, strength (already decayed)
#endif

float psiAt(int x, int y) {
    return texelFetch(u_psi, ivec2(wrapX(x, u_size.x), clampY(y, u_size.y)), 0).r;
}

void main() {
    ivec2 px = ivec2(gl_GlobalInvocationID.xy);
    if (px.x >= u_size.x || px.y >= u_size.y) return;

    vec2 ll = lonlatAt(px, u_size);

#if DOMAIN == 0
    float dlat = PI / float(u_size.y);   // latitude step between rows (positive)
    float dlon = 2.0 * PI / float(u_size.x);

    // Row y-1 is HIGHER latitude: dpsi/dphi = (psi(y-1) - psi(y+1)) / (2 dlat).
    float dpsi_dphi = (psiAt(px.x, px.y - 1) - psiAt(px.x, px.y + 1)) / (2.0 * dlat);
    float dpsi_dlam = (psiAt(px.x + 1, px.y) - psiAt(px.x - 1, px.y)) / (2.0 * dlon);

    float cosl = max(cos(ll.y), 0.017);  // clamp at ~cos(89 deg)
    float u = -dpsi_dphi;
    float v = dpsi_dlam / cosl;

    // Equirect advection degrades toward the caps; fade velocity out there
    // (the polar patches own that region and run unfaded).
    float fade = texture(u_profile_stamp, latProfileUV(ll.y)).b;
    u *= fade;
    v *= fade;

    // Convective outbreak outflow.
    for (int i = 0; i < u_outbreak_count; ++i) {
        vec4 ob = u_outbreaks[i];
        float dlon = mod(ll.x - ob.x + 3.0 * PI, 2.0 * PI) - PI;
        vec2 dxy = vec2(dlon * cosl, ll.y - ob.y);
        float r = length(dxy);
        if (r > 1e-5 && r < ob.z * 3.0) {
            float q = r / ob.z;
            u += ob.w * (dxy.x / r) * q * exp(-q * q);
            v += ob.w * (dxy.y / r) * q * exp(-q * q);
        }
    }
    imageStore(out_vel, px, vec4(u, v, 0.0, 0.0));
#else
    // Patch derivatives in st (radians), then rotate to (east, north):
    //   dpsi/drho   = ds . e_rho,   dpsi/dtheta = rho * (ds . e_theta)
    //   u = POLE_SIGN * dpsi/drho,  v = (1/sin rho) * dpsi/dtheta
    float dstep = 2.0 * u_rho_max / float(u_size.x);
    vec2 ds = vec2(
        (psiAt(px.x + 1, px.y) - psiAt(px.x - 1, px.y)) / (2.0 * dstep),
        (psiAt(px.x, px.y + 1) - psiAt(px.x, px.y - 1)) / (2.0 * dstep)
    );
    vec2 st = patchStFromPix(vec2(px) + 0.5, u_size);
    float rho = length(st);
    float u = 0.0;
    float v = 0.0;
    if (rho > 1e-4) {
        vec2 er = st / rho;
        vec2 et = vec2(-er.y, er.x);
        float dpsi_drho = dot(ds, er);
        float dpsi_dtheta = rho * dot(ds, et);
        u = POLE_SIGN * dpsi_drho;
        v = dpsi_dtheta / max(sin(rho), 1e-4);
    }
    imageStore(out_vel, px, vec4(u, v, 0.0, 0.0));
#endif
}
